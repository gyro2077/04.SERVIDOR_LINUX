<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="desktop_client.SetupWindow"
        Title="Configuracion - Cliente SOAP"
        Width="450"
        Height="280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <StackPanel Margin="30" Spacing="15">
        <TextBlock Text="Configuracion del Servidor"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <TextBlock Text="Ingrese la direccion IP o nombre del servidor donde se ejecuta el servicio SOAP."
                   TextWrapping="Wrap"
                   Foreground="#636E72"
                   FontSize="12"
                   Margin="0,0,0,10"/>

        <StackPanel Spacing="5">
            <TextBlock Text="Direccion del Servidor:" FontWeight="Bold"/>
            <TextBox x:Name="TxtServerAddress"
                     Watermark="localhost o IP (ej: 192.168.1.100)"
                     MaxWidth="400"
                     HorizontalAlignment="Stretch"/>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="Puerto:" FontWeight="Bold"/>
            <TextBox x:Name="TxtPort"
                     Text="8080"
                     MaxWidth="400"
                     HorizontalAlignment="Left"/>
        </StackPanel>

        <TextBlock x:Name="TxtError"
                   Text=""
                   Foreground="#D63031"
                   FontSize="11"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   MaxWidth="400"/>

        <Button x:Name="BtnConnect"
                Content="CONECTAR"
                Width="150"
                Height="40"
                HorizontalAlignment="Center"
                Background="#00A8FF"
                Foreground="White"
                FontWeight="Bold"
                Margin="0,15,0,0"/>
    </StackPanel>
</Window>
