<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="desktop_client.Views.SetupWindow"
        Title="Configuración de Red - Cliente SOAP"
        Width="450" Height="300"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        ExtendClientAreaToDecorationsHint="False">

    <Border Padding="30" Background="#1E293B" CornerRadius="12" Margin="15">
        <StackPanel Spacing="15">
            <TextBlock Text="Configuración del Servidor"
                       FontSize="20" FontWeight="Bold" Foreground="#F8FAFC"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Text="Ingrese la dirección IP y puerto del backend SOAP."
                       Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Dirección del Servidor:" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                <TextBox x:Name="TxtServerAddress" PlaceholderText="localhost o IP" Background="#334155" Foreground="White" BorderBrush="#6366F1" PlaceholderForeground="#94A3B8"/>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Puerto:" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                <TextBox x:Name="TxtPort" Text="8080" Background="#334155" Foreground="White" BorderBrush="#6366F1" MaxWidth="120" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock x:Name="TxtError" Foreground="#EF4444" FontSize="12" IsVisible="False" TextWrapping="Wrap"/>

            <Button x:Name="BtnConnect" Content="CONECTAR" Width="140" Height="40"
                    HorizontalAlignment="Center" Background="#6366F1" Foreground="White"
                    FontWeight="Bold" CornerRadius="8" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</Window>