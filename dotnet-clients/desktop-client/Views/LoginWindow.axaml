<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="desktop_client.Views.LoginWindow"
        Title="Acceso Corporativo"
        Width="400" Height="360"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Border Padding="30" Background="#1E293B" CornerRadius="12" Margin="15">
        <StackPanel Spacing="16">
            <TextBlock Text="Autenticación Segura"
                       FontSize="22" FontWeight="Bold" Foreground="#F8FAFC"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Text="Ingrese sus credenciales de acceso para usar el conversor."
                       Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Usuario:" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                <TextBox x:Name="TxtUsername" PlaceholderText="Ej: MONSTER" Background="#334155" Foreground="White" BorderBrush="#6366F1" PlaceholderForeground="#94A3B8"/>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Contraseña:" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                <TextBox x:Name="TxtPassword" PasswordChar="•" Background="#334155" Foreground="White" BorderBrush="#6366F1"/>
            </StackPanel>

            <TextBlock x:Name="TxtAuthError" Foreground="#EF4444" FontSize="12" IsVisible="False" TextWrapping="Wrap" HorizontalAlignment="Center"/>

            <Button x:Name="BtnLogin" Content="INGRESAR" Width="150" Height="42"
                    HorizontalAlignment="Center" Background="#8B5CF6" Foreground="White"
                    FontWeight="Bold" CornerRadius="8" Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</Window>