@model web_client.Models.ConversionViewModel

@{
    ViewData["Title"] = "Conversor Universal";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="glass-card p-5">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom" style="border-color: rgba(255,255,255,0.1) !important;">
                <h4 class="mb-0 fw-bold text-white d-flex align-items-center">
                    <i class="bi bi-arrow-left-right text-primary me-3" style="font-size: 1.8rem;"></i> Conversor SOAP
                </h4>
                <span class="badge rounded-pill" style="background: rgba(34,197,94,0.2); color: #86efac; font-size: 0.75rem; padding: 0.4rem 0.8rem;">
                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>VPS Conectado
                </span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger border-0 mb-4" style="background: rgba(239, 68, 68, 0.2); color: #fca5a5; border-radius: 0.75rem;">
                    <i class="bi bi-x-circle-fill me-2"></i>@Model.ErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success border-0 mb-4 text-center py-3" style="background: rgba(34, 197, 94, 0.2); color: #86efac; border-radius: 0.75rem; font-size: 1.1rem;">
                    <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
                </div>
            }

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Category" class="form-label text-light fw-semibold small">Categoría de Unidad</label>
                    <select asp-for="Category" asp-items="Model.Categories" class="form-select form-select-lg form-control-custom" id="cmbCategory" onchange="updateUnits()">
                    </select>
                </div>

                <div class="row g-4 mb-4 align-items-center">
                    <div class="col-md-5">
                        <label asp-for="FromUnit" class="form-label text-light fw-semibold small">Convertir desde</label>
                        <select asp-for="FromUnit" class="form-select form-control-custom" id="cmbFrom"></select>
                    </div>

                    <div class="col-md-2 text-center">
                        <i class="bi bi-arrow-right text-primary d-none d-md-inline" style="font-size: 1.5rem;"></i>
                    </div>

                    <div class="col-md-5">
                        <label asp-for="ToUnit" class="form-label text-light fw-semibold small">Hacia destino</label>
                        <select asp-for="ToUnit" class="form-select form-control-custom" id="cmbTo"></select>
                    </div>
                </div>

                <div class="mb-5">
                    <label asp-for="InputValue" class="form-label text-light fw-semibold small">Valor numérico</label>
                    <input asp-for="InputValue" class="form-control form-control-lg form-control-custom" type="number" step="any" min="0" placeholder="0.0" />
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-gradient btn-lg py-3 shadow">
                        <i class="bi bi-calculator-fill me-2"></i> Procesar Conversión
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const units = {
            "Mass": ["KILOGRAM", "GRAM", "POUND", "OUNCE"],
            "Length": ["METER", "KILOMETER", "CENTIMETER", "MILE", "YARD", "FOOT", "INCH"],
            "Temperature": ["CELSIUS", "FAHRENHEIT", "KELVIN"]
        };

        function updateUnits() {
            const category = document.getElementById("cmbCategory").value;
            const fromSelect = document.getElementById("cmbFrom");
            const toSelect = document.getElementById("cmbTo");

            fromSelect.innerHTML = "";
            toSelect.innerHTML = "";

            if (units[category]) {
                units[category].forEach(u => {
                    fromSelect.add(new Option(u, u));
                    toSelect.add(new Option(u, u));
                });
                if (toSelect.options.length > 1) {
                    toSelect.selectedIndex = 1;
                }
            }
        }

        document.addEventListener('DOMContentLoaded', function() { updateUnits(); });
    </script>
}