@model web_client.Controllers.ServerConfigViewModel

@{
    ViewData["Title"] = "Configurar Servidor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-gear me-2"></i>Configuracion del Servidor SOAP
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">
                        Configure la direccion IP y puerto del servidor donde se ejecuta el servicio SOAP.
                    </p>

                    <form asp-action="Configure" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="ServerAddress" class="form-label fw-bold"></label>
                            <input asp-for="ServerAddress" class="form-control" placeholder="localhost o 192.168.1.100" />
                            <span asp-validation-for="ServerAddress" class="text-danger small"></span>
                            <div class="form-text">IP o nombre del servidor (ej: localhost, 192.168.100.171)</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ServerPort" class="form-label fw-bold"></label>
                            <input asp-for="ServerPort" class="form-control" placeholder="8080" />
                            <span asp-validation-for="ServerPort" class="text-danger small"></span>
                            <div class="form-text">Puerto del servicio (por defecto: 8080)</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save me-2"></i>Guardar Configuracion
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
