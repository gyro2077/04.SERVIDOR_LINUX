#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/gyro/Documents/ULTIMO_SEMESTRE/ARQUITECTURA/04.SERVIDOR/mobile-client/node_modules/.pnpm/lan-network@0.2.1/node_modules/lan-network/node_modules:/home/gyro/Documents/ULTIMO_SEMESTRE/ARQUITECTURA/04.SERVIDOR/mobile-client/node_modules/.pnpm/lan-network@0.2.1/node_modules:/home/gyro/Documents/ULTIMO_SEMESTRE/ARQUITECTURA/04.SERVIDOR/mobile-client/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/gyro/Documents/ULTIMO_SEMESTRE/ARQUITECTURA/04.SERVIDOR/mobile-client/node_modules/.pnpm/lan-network@0.2.1/node_modules/lan-network/node_modules:/home/gyro/Documents/ULTIMO_SEMESTRE/ARQUITECTURA/04.SERVIDOR/mobile-client/node_modules/.pnpm/lan-network@0.2.1/node_modules:/home/gyro/Documents/ULTIMO_SEMESTRE/ARQUITECTURA/04.SERVIDOR/mobile-client/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../lan-network/dist/lan-network-cli.js" "$@"
else
  exec node  "$basedir/../../../../lan-network/dist/lan-network-cli.js" "$@"
fi
